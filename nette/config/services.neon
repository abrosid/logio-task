services:
    - Nette\Caching\Cache
    cache.storage: Nette\Caching\Storages\FileStorage(%appDir%/../data)
    - App\Core\RouterFactory::createRouter

    # -------------------------------------------------------
    # Storage adapters for product data (switch ES ↔ MySQL here)
    # Only one adapter can be active at a time
    # -------------------------------------------------------
    mySQLAdapter: App\Infrastructure\MySQL\MySQLAdapter
#   elasticSearchAdapter: App\Infrastructure\ElasticSearch\ElasticSearchAdapter

    # -------------------------------------------------------
    # Cache adapter for PRODUCT data (switch File ↔ Redis here)
    # -------------------------------------------------------
    productCacheAdapter: App\Infrastructure\FileStorage\FileCacheAdapter
#   productCacheAdapter: App\Infrastructure\Redis\RedisAdapter

    # -------------------------------------------------------
    # Storage adapter for TRACKING data (switch File ↔ Redis here)
    # -------------------------------------------------------
    trackingStorageAdapter: App\Infrastructure\FileStorage\FileCacheAdapter
#   trackingStorageAdapter: App\Infrastructure\Redis\RedisAdapter

    # -------------------------------------------------------
    # Repositories – explicit cache wiring to avoid ambiguity
    # -------------------------------------------------------
    - App\Infrastructure\Product\ProductRepository(
        cacheAdapter: @productCacheAdapter
      )

    - App\Infrastructure\Tracking\TrackingRepository(
        cacheAdapter: @trackingStorageAdapter
      )

    # -------------------------------------------------------
    # Domain Use Cases
    # -------------------------------------------------------
    - App\Domain\Product\UseCase\GetProductDetailUseCase
    - App\Domain\Product\UseCase\GetProductTrackingUseCase
